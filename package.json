{
  "name": "camper-rent-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=!@camper-rent/backend",
    "dev:backend": "pnpm --filter @camper-rent/backend dev",
    "dev:backend:logs": "pnpm --filter @camper-rent/backend dev:logs",
    "dev:local": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "turbo run format"
  },
  "devDependencies": {
    "turbo": "^2.8.20"
  }
}
